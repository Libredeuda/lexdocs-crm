# ============================================================
# LexDocs / LibreApp — Variables de entorno
# Copia este archivo a .env y rellena los valores.
# NUNCA commitees .env (está en .gitignore).
# ============================================================

# ---- FRONTEND (Vite, prefijo VITE_) ------------------------
# Supabase (proyecto correspondiente al entorno)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Branding
VITE_APP_NAME=LexDocs

# Stripe (clave publicable: pk_test_... en dev, pk_live_... en prod)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Anthropic (solo si se usa desde el frontend — preferible moverlo a Edge Function)
VITE_ANTHROPIC_API_KEY=

# Web Push (clave PÚBLICA VAPID, base64url)
VITE_VAPID_PUBLIC_KEY=

# ============================================================
# SECRETS DE EDGE FUNCTIONS (Supabase)
# No van en .env local. Se configuran con:
#   supabase secrets set KEY=VALUE --project-ref <ref>
# Se listan aquí solo como referencia.
# ============================================================

# ---- Supabase (automático en Edge Functions, no hace falta setearlos) ----
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_ANON_KEY

# ---- Anthropic (Carlota, ai-agent-respond, automation-runner, verify-document, ai-lead-scorer) ----
ANTHROPIC_API_KEY=sk-ant-xxx

# ---- Resend (email transaccional) ----
RESEND_API_KEY=re_xxx
FROM_EMAIL=LibreApp <noreply@libredeudaabogados.com>

# ---- Stripe (clave SECRETA + webhook) ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- WhatsApp Business Cloud API (Meta) ----
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_TEMPLATE_ASSIGNMENT=case_assignment
WHATSAPP_TEMPLATE_MESSAGE=new_message

# ---- Meta Ads (webhook de leads) ----
META_VERIFY_TOKEN=libreapp_meta_2026
META_PAGE_ACCESS_TOKEN=
# App Secret de la app de Meta (Settings → Basic → App Secret).
# Imprescindible en producción: valida la firma HMAC-SHA256 que Meta incluye en
# cada POST del webhook (X-Hub-Signature-256). Sin él, los webhooks aceptan
# tráfico sin verificar origen.
META_APP_SECRET=

# ---- Web Push VAPID ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@libredeudaabogados.com

# ---- Google Calendar OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://<project-ref>.supabase.co/functions/v1/gcal-oauth-callback

# ---- URL de la app (para enlaces en emails, redirects, etc.) ----
APP_URL=https://app.libredeudaabogados.com

# ---- Secrets internos de Edge Functions ----
# Protege el modo cron de automation-runner (cabecera X-Cron-Secret).
# Sin él, cualquiera podría disparar el procesamiento de runs.
CRON_SECRET=

# Protege llamadas entre Edge Functions (cabecera X-Internal-Secret) y
# webhooks internos que invocan ai-agent-respond u otras funciones sin
# sesión de usuario.
INTERNAL_FUNCTION_SECRET=
